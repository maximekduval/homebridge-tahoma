{
  "name": "homebridge-tahoma-mk",
  "displayName": "Homebridge TaHoma MK",
  "version": "1.0.0",
  "description": "Platform plugin for TaHoma and Cozytouch services (Somfy,Atlantic,Thermor,Sauter): https://github.com/maximekduval/homebridge-tahoma",
  "author": "maximekduval <maximekduval@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/maximekduval/homebridge-tahoma.git"
  },
  "bugs": {
    "url": "https://github.com/maximekduval/homebridge-tahoma/issues"
  },
  "engines": {
    "node": ">=20.12.0",
    "homebridge": ">=1.6.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "watch": "npm run build && npm link && nodemon",
    "clean": "rimraf ./dist",
    "build": "rimraf ./dist && tsc",
    "prepublishOnly": "npm run lint && npm run test && npm run build && npm version patch --m 'Release %s'",
    "postpublish": "npm run clean"
  },
  "keywords": [
    "homebridge-plugin",
    "tahoma",
    "cozytouch",
    "somfy",
    "connexoon"
  ],
  "homepage": "https://github.com/maximekduval/homebridge-tahoma#readme",
  "dependencies": {
    "moment": "^2.30.1",
    "overkiz-client": "^1.0.20"
  },
  "devDependencies": {
    "@types/node": "^22.8.7",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.14.0",
    "homebridge": "^1.8.5",
    "nodemon": "^3.1.7",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  },
  "funding": {
    "url": "https://github.com/sponsors/maximekduval"
  }
}
